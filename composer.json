{
    "name": "gbu/semester-online-registration",
    "description": "GBU Semester Online Registration System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "razorpay/razorpay": "^2.9",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
